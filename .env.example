# =====================================================
# CloudNative University — Community Edition (CE)
# Environment Variables — Copy this file to .env
# =====================================================
# IMPORTANT: Never commit your actual .env file.
# .env is listed in .gitignore for this reason.

# ── Container Registry (Optional) ────────────────────
# Use these if you want to pull pre-built images from a Registry (Docker Hub, GHCR, etc.)
# Instead of building locally. Leave as is for local builds.
# ORCHESTRATOR_IMAGE=youruser/cnu-orchestrator:latest
# FRONTEND_IMAGE=youruser/cnu-frontend:latest

# ── Student Identity ─────────────────────────────────
# These credentials create the default student account on first startup.
STUDENT_NAME=Your Full Name
STUDENT_EMAIL=you@example.com
STUDENT_KEY=change-this-to-a-strong-key

# ── Admin Credentials ────────────────────────────────
# Password for the built-in instructor account (admin@cloudmaster.com).
# If not set, the admin account will NOT be created.
ADMIN_PASSWORD=change-this-to-a-strong-password

# ── Database ─────────────────────────────────────────
# Only change if using an external PostgreSQL instance.
DB_USER=admin
DB_PASSWORD=change-this-db-password
DB_NAME=cloudmaster

# ── Lab Content Path ─────────────────────────────────
# Absolute path on your HOST machine to the lab content folder.
# Must contain: guia.json, project/, checkers/, docker-compose.yml
LAB_CONTENT_PATH=./labs
LAB_HOST_PATH=/tmp/cnu_labs

